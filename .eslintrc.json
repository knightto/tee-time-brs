{
  "env": {
    "node": true,
    "es2021": true,
    "browser": true,
    "serviceworker": true
  },
  "extends": [
    "eslint:recommended",
    "prettier"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "script"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": ["warn", { "allow": ["log", "warn", "error"] }],
    "no-empty": "off",
    "no-inner-declarations": "off",
    "no-useless-escape": "off"
  }
}
